{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Rails Server",
			"type": "shell",
			"command": "rails",
			"args": ["server", "-b", "0.0.0.0"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Rails Console",
			"type": "shell",
			"command": "rails",
			"args": ["console"],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "new"
			}
		},
		{
			"label": "Run Migrations",
			"type": "shell",
			"command": "rails",
			"args": ["db:migrate"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			}
		}
	]
}