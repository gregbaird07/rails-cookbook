<% content_for :title, "Edit Profile" %>

<div class="auth-container">
  <div class="auth-card">
    <h2 class="auth-title">Edit Profile</h2>
    
    <%= form_with model: @user, local: true, class: "auth-form" do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      
      <div class="form-row">
        <div class="form-group col-md-6">
          <%= f.label :first_name, "First Name" %>
          <%= f.text_field :first_name, class: "form-control", required: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :last_name, "Last Name" %>
          <%= f.text_field :last_name, class: "form-control", required: true %>
        </div>
      </div>
      
      <div class="form-group">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, class: "form-control", required: true %>
      </div>
      
      <div class="form-group">
        <%= f.label :password, "Password (leave blank to keep current)" %>
        <%= f.password_field :password, class: "form-control", placeholder: "New password (optional)" %>
      </div>
      
      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm new password" %>
      </div>
      
      <div class="form-group">
        <%= f.submit "Update Profile", class: "btn btn-primary btn-block" %>
      </div>
    <% end %>
    
    <div class="auth-links">
      <%= link_to "Back to Profile", user_path(@user), class: "btn btn-link" %>
    </div>
  </div>
</div>
